rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} { allow read, write: if false; }

    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'elo', 'displayName']) &&
               data.uid == userId &&
               data.uid == request.auth.uid &&
               data.elo is number &&
               data.displayName is string && data.displayName.size() <= 100;
      }

      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(userId) && userId == request.auth.uid && isValidUser(incoming());
      allow update: if isSignedIn() && userId == request.auth.uid && (
        incoming().diff(existing()).affectedKeys().hasOnly(['elo']) && incoming().elo is number
      );
    }

    match /queue/{userId} {
      function isValidQueue(data) {
        return data.keys().hasAll(['uid', 'elo', 'joinedAt']) &&
               data.uid == userId &&
               data.uid == request.auth.uid &&
               data.elo is number &&
               data.joinedAt == request.time;
      }
      
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(userId) && userId == request.auth.uid && isValidQueue(incoming());
      allow delete: if isSignedIn(); // Allow anyone to delete from queue when matching
    }

    match /games/{gameId} {
      function isValidGame(data) {
        return data.keys().hasAll(['whiteId', 'blackId', 'fen', 'status', 'turn', 'createdAt', 'updatedAt']) &&
               data.whiteId is string && data.whiteId.size() <= 128 &&
               data.blackId is string && data.blackId.size() <= 128 &&
               data.fen is string && data.fen.size() <= 150 &&
               data.status in ["playing", "white_won", "black_won", "draw"] &&
               data.turn in ["w", "b"] &&
               data.createdAt == request.time &&
               data.updatedAt == request.time;
      }

      function isParticipant() {
        return request.auth.uid == existing().whiteId || request.auth.uid == existing().blackId;
      }

      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(gameId) && 
        (incoming().whiteId == request.auth.uid || incoming().blackId == request.auth.uid) && 
        isValidGame(incoming());
      
      allow update: if isSignedIn() && isParticipant() && (
        (incoming().diff(existing()).affectedKeys().hasOnly(['fen', 'status', 'turn', 'updatedAt']) &&
        incoming().fen is string && incoming().fen.size() <= 150 &&
        incoming().status in ["playing", "white_won", "black_won", "draw"] &&
        incoming().turn in ["w", "b"] &&
        incoming().updatedAt == request.time)
        ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['fen', 'status', 'turn', 'updatedAt', 'pgn']) &&
        incoming().fen is string && incoming().fen.size() <= 150 &&
        incoming().status in ["playing", "white_won", "black_won", "draw"] &&
        incoming().turn in ["w", "b"] &&
        incoming().pgn is string && incoming().pgn.size() <= 5000 &&
        incoming().updatedAt == request.time)
      );
    }
  }
}
